          "value": "claude-haiku-4-5"
        },
        "messages": {
          "values": [
            {
              "content": "=You are the placement office at Waltham International College (WIC) in Barking, London.\n\nWrite a professional and warm placement assessment email to:\nStudent Name: {{ $json['Student Name'] }}\nEmployer: {{ $json['Employer'] }}\nPlacement Start Date: {{ $json['Placement Start Date'] }}\n\nThe email should:\n- Thank them for their hard work on placement\n- Ask them to complete and return the attached placement assessment form\n- Mention the deadline is in 2 weeks from today\n- Be friendly, encouraging and professional\n- Be under 150 words\n- Sound like it was written by a real person\n\nEnd with:\nKind regards,\nWIC Placement Team\nWaltham International College, Barking\n\nReturn only the email body. No subject line."
            }
          ]
        },
        "options": {
          "system": "You write warm, professional placement emails on behalf of Waltham International College. Always be encouraging and natural. Never sound automated.",
          "maxTokens": 400
        }
      },
